# ════════════════════════════════════════════════════════════════════════════
# Droit du Travail RAG — Variables d'environnement
# ════════════════════════════════════════════════════════════════════════════

# ── OBLIGATOIRE — Clé API Anthropic ──────────────────────────────────────────
# Obtenir une clé sur : https://console.anthropic.com/
ANTHROPIC_API_KEY=******************************

# ── OPTIONNEL — Modèle Claude à utiliser ─────────────────────────────────────
# Valeur par défaut : claude-sonnet-4-5
# Autres options   : claude-opus-4-6 (plus puissant), claude-haiku-4-5-20251001 (plus rapide)
# CLAUDE_MODEL=claude-sonnet-4-5

# ── OPTIONNEL — Nombre de chunks récupérés ───────────────────────────────────
# Valeur par défaut : 5
# TOP_K=5
